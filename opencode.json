    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*/.env": "deny",
      "*/.env.*": "deny",
      "config.toml": "deny",
      "*/config.toml": "deny",
      "secrets/**": "deny",
      "*/secrets/**": "deny",
      ".claude/**": "deny",
      "*/.claude/**": "deny",
      ".claude/skills/**": "allow",
      "*/.claude/skills/**": "allow",
      "~/.aws/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.config/gh/**": "deny",
      "~/.config/git/**": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.netrc": "deny",
      "~/.kube/**": "deny",
      "~/.config/git/ignore": "allow",
      "~/.config/git/attributes": "allow"
    },
    "edit": {
      "*": "allow",
      ".git/**": "deny",
      "*/.git/**": "deny",
      ".claude/**": "deny",
      "*/.claude/**": "deny"
    },
    "webfetch": "allow",
    "external_directory": {
      "*": "deny",
      "~/.config/git/ignore": "allow",
      "~/.config/git/attributes": "allow"
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    }
  },
  "enabled_providers": [
    "openai"
  ],
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "textVerbosity": "medium"
          }
        }
      }
    }
  }
