{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "./run_tests.sh": "allow",
      "./run_tests.sh *": "allow",
      ".venv/bin/pyright": "allow",
      ".venv/bin/pyright *": "allow",
      "awk *": "allow",
      "cat *": "allow",
      "diff *": "allow",
      "git branch --list *": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "git log": "allow",
      "git reflog *": "allow",
      "git reflog": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git status": "allow",
      "git tag --list *": "allow",
      "git tag --list": "allow",
      "git tag -l *": "allow",
      "git tag -l": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "yarn lint *": "allow",
      "yarn lint": "allow",
      "yarn lint:files *": "allow",
      "yarn lint:files": "allow",
      "yarn types:build *": "allow",
      "yarn types:build": "allow",
      "./cdk-wrapper.sh": "deny",
      "./cdk-wrapper.sh *": "deny",
      "./cdk.sh": "deny",
      "./cdk.sh *": "deny",
      ".venv/bin/pip*": "deny",
      ".venv/bin/python*": "deny",
      "cdk": "deny",
      "cdk *": "deny",
      "cpan": "deny",
      "cpan *": "deny",
      "cpanm": "deny",
      "cpanm *": "deny",
      "curl": "deny",
      "curl *": "deny",
      "enc2xs": "deny",
      "enc2xs *": "deny",
      "find": "deny",
      "find *": "deny",
      "git add": "deny",
      "git add *": "deny",
      "git checkout": "deny",
      "git checkout *": "deny",
      "git commit": "deny",
      "git commit *": "deny",
      "git stash": "deny",
      "git stash *": "deny",
      "h2ph": "deny",
      "h2ph *": "deny",
      "h2xs": "deny",
      "h2xs *": "deny",
      "hatch": "deny",
      "hatch *": "deny",
      "ipython": "deny",
      "ipython *": "deny",
      "json_pp": "deny",
      "json_pp *": "deny",
      "libnetcfg": "deny",
      "libnetcfg *": "deny",
      "nox": "deny",
      "nox *": "deny",
      "perl": "deny",
      "perl *": "deny",
      "perlbug": "deny",
      "perlbug *": "deny",
      "perldoc": "deny",
      "perldoc *": "deny",
      "perlivp": "deny",
      "perlivp *": "deny",
      "pip": "deny",
      "pip *": "deny",
      "pip3": "deny",
      "pip3 *": "deny",
      "pipenv": "deny",
      "pipenv *": "deny",
      "pipx": "deny",
      "pipx *": "deny",
      "pl2pm": "deny",
      "pl2pm *": "deny",
      "pod2html": "deny",
      "pod2html *": "deny",
      "pod2man": "deny",
      "pod2man *": "deny",
      "pod2text": "deny",
      "pod2text *": "deny",
      "pod2usage": "deny",
      "pod2usage *": "deny",
      "poetry": "deny",
      "poetry *": "deny",
      "prove": "deny",
      "prove *": "deny",
      "py": "deny",
      "py *": "deny",
      "python": "deny",
      "python *": "deny",
      "python2": "deny",
      "python2 *": "deny",
      "python3*": "deny",
      "pythonw": "deny",
      "pythonw *": "deny",
      "pyw": "deny",
      "pyw *": "deny",
      "pypy": "deny",
      "pypy *": "deny",
      "rye": "deny",
      "rye *": "deny",
      "splain": "deny",
      "splain *": "deny",
      "tox": "deny",
      "tox *": "deny",
      "uv": "deny",
      "uv *": "deny",
      "venv/bin/pip*": "deny",
      "venv/bin/python*": "deny",
      "wget": "deny",
      "wget *": "deny",
      "xsubpp": "deny",
      "xsubpp *": "deny"
    },
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*/.env": "deny",
      "*/.env.*": "deny",
      "config.toml": "deny",
      "*/config.toml": "deny",
      "secrets/**": "deny",
      "*/secrets/**": "deny",
      ".claude/**": "deny",
      "*/.claude/**": "deny",
      "~/.aws/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.config/gh/**": "deny",
      "~/.config/git/**": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.netrc": "deny",
      "~/.kube/**": "deny",
      "~/.config/git/ignore": "allow",
      "~/.config/git/attributes": "allow"
    },
    "edit": {
      "*": "allow",
      ".git/**": "deny",
      "*/.git/**": "deny",
      ".claude/**": "deny",
      "*/.claude/**": "deny"
    },
    "webfetch": "ask",
    "external_directory": {
      "*": "deny",
      "~/.config/git/ignore": "allow",
      "~/.config/git/attributes": "allow"
    }
  },
  "enabled_providers": [
    "openai"
  ],
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "textVerbosity": "medium"
          }
        }
      }
    }
  }
}
